#!/usr/bin/env python3
"""Mock `uvx` for the eval battery.

The skills always invoke the CLI as `uvx --from expedait-cli expedait <args...>`. This
shim recognizes exactly that prefix and forwards `<args...>` to the sibling mock
`expedait`. Any other `uvx` invocation exits non-zero — tests should only exercise the
documented invocation, and an unexpected one is worth surfacing.
"""

import os
import sys
from pathlib import Path


def main():
    args = sys.argv[1:]
    if args[:3] == ["--from", "expedait-cli", "expedait"]:
        expedait = Path(__file__).resolve().parent / "expedait"
        os.execv(sys.executable, [sys.executable, str(expedait), *args[3:]])
    sys.stderr.write(
        "mock uvx: only `uvx --from expedait-cli expedait ...` is supported; got: "
        + " ".join(args) + "\n"
    )
    return 2


if __name__ == "__main__":
    sys.exit(main())
